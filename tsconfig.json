{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "module": "NodeNext",
    "moduleDetection": "legacy",
    "moduleResolution": "NodeNext",
    "noImplicitAny": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2023",
    "types": ["node"]
  },
  "include": [
    "src/**/*.js",
    "src/**/*.ts",
    "scripts/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "build-scripts",
    "build-test",
    "dist"
  ]
}
