{
  "name": "dashtop",
  "version": "0.1.0",
  "description": "Electron project cockpit prototype for dashboards and development workflows.",
  "main": "src/main/main.js",
  "desktopName": "dashtop",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "smoke": "electron . --smoke --no-sandbox",
    "lint": "node scripts/check-js.mjs",
    "test": "node --test",
    "package": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "dashboard",
    "projects"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "dev.dashtop.app",
    "productName": "Dashtop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "!**/*.map",
      "!test/**/*",
      "!scripts/**/*",
      "!dist/**/*",
      "!*.md",
      "!Makefile"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "linux": {
      "category": "Development",
      "icon": "src/renderer/assets/dashtop-icon.png",
      "syncDesktopName": true,
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^42.3.2",
    "electron-builder": "^26.15.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  }
}
