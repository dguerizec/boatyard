{
  "name": "dashtop",
  "version": "0.2.0",
  "description": "Electron project cockpit prototype for dashboards and development workflows.",
  "main": "src/main/main.js",
  "desktopName": "dashtop",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "smoke": "electron . --smoke --no-sandbox",
    "lint": "node scripts/check-js.mjs",
    "test": "node --test",
    "package": "electron-builder --dir",
    "dist": "electron-builder --publish never",
    "dist:linux": "electron-builder --linux AppImage --x64 --publish never",
    "dist:mac": "electron-builder --mac dmg zip --x64 --publish never"
  },
  "keywords": [
    "electron",
    "dashboard",
    "projects"
  ],
  "author": "David Guerizec <david@guerizec.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dguerizec/dashtop.git"
  },
  "bugs": {
    "url": "https://github.com/dguerizec/dashtop/issues"
  },
  "homepage": "https://github.com/dguerizec/dashtop#readme",
  "build": {
    "appId": "dev.dashtop.app",
    "productName": "Dashtop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "!**/*.map",
      "!test/**/*",
      "!scripts/**/*",
      "!dist/**/*",
      "!*.md",
      "!Makefile"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "linux": {
      "category": "Development",
      "icon": "src/renderer/assets/dashtop-icon.png",
      "syncDesktopName": true,
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^42.3.2",
    "electron-builder": "^26.15.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  }
}
